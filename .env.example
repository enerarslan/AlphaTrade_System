# AlphaTrade local development environment

# App
APP_ENV=development
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=text

# Security
JWT_SECRET_KEY=replace_with_a_64_hex_char_secret
SECURITY__JWT_SECRET_KEY=replace_with_a_64_hex_char_secret
JWT_ALGORITHM=HS256
SECURITY__JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
SECURITY__JWT_EXPIRATION_MINUTES=60
REQUIRE_AUTH=true
SECURITY__REQUIRE_AUTH=true
ALLOW_PUBLIC_HEALTH=true
SECURITY__ALLOW_PUBLIC_HEALTH_CHECK=true
API_KEYS=

# Dashboard auth
DASHBOARD_USERS=admin:admin
FRONTEND_BASE_URL=http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=postgresql://postgres:trading_password@127.0.0.1:5433/quant_trading
DATABASE__HOST=127.0.0.1
DATABASE__PORT=5433
DATABASE__NAME=quant_trading
DATABASE__USER=postgres
DATABASE__PASSWORD=trading_password

# Redis
REDIS__HOST=127.0.0.1
REDIS__PORT=6379
REDIS__DB=0
REDIS__PASSWORD=

# Alpaca
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_PAPER_TRADING=true
ALPACA_DATA_FEED=iex
ALPACA__API_KEY=
ALPACA__API_SECRET=
ALPACA__BASE_URL=https://paper-api.alpaca.markets
ALPACA__DATA_URL=https://data.alpaca.markets
ALPACA__PAPER_TRADING=true

# Optional market-data providers for dashboard widgets
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Optional alerting integrations
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_TO_ADDRESSES=
PAGERDUTY_SERVICE_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBERS=
